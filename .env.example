# ── Aviation BI — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── AI Features (optional) ────────────────────────────────────────────────────
# Enables: NL→SQL (Ask the Data), AI insight narratives on charts.
# Get a key at: https://console.anthropic.com
# Without this key, all 13 dashboard pages and all ML models still work.
ANTHROPIC_API_KEY=

# ── Database (auto-configured by Docker) ──────────────────────────────────────
# No changes needed if running via docker compose.
# Only override this for local development without Docker.
DATABASE_URL=postgresql://avbi:avbi@postgres:5432/aviation_bi

# ── Local development only ────────────────────────────────────────────────────
# If running the backend without Docker (uvicorn backend.main:app),
# unset DATABASE_URL so the app falls back to the local parquet file:
#   unset DATABASE_URL && uvicorn backend.main:app --reload --port 8000
